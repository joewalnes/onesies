#!/usr/bin/swift

// apple-ai-api — OpenAI-compatible HTTP API for Apple's on-device Foundation Models
//
// Usage:
//   ./macos/apple-ai-api [options]
//
// Options:
//   -p, --port PORT       Port to listen on (default: 8080)
//   -k, --api-key KEY     Require this API key for all requests (optional)
//   -d, --debug           Enable debug logging of requests and responses
//   -h, --help            Show this help message
//
// Exposes Apple's on-device LLM via an OpenAI-compatible REST API.
// Point any OpenAI client at http://localhost:8080 and it just works.
//
// Includes simple interactive web-app.
//
// Joe Walnes <joe@walnes.com>, 2026, MIT License
// https://github.com/joewalnes/onesies

import Foundation
import Network
@preconcurrency import FoundationModels

// AIDEV-NOTE: User Configuration - Easy to modify settings
struct Config {
    static var port: UInt16 = 8080
    static var apiKey: String? = nil
    static var debug: Bool = false
    static var skipModelCheck: Bool = false // for testing the HTTP layer without Apple Intelligence
    static let host: NWEndpoint.Host = .ipv4(.loopback) // localhost only for security
    static let maxRequestSize = 10 * 1024 * 1024 // 10 MB
    static let modelId = "apple-foundation-model"
    static let modelName = "Apple Foundation Model (~3B on-device)"
}

// MARK: - CLI argument parsing

func printHelp() {
    let help = """
    apple-ai-api — OpenAI-compatible API for Apple's on-device Foundation Models

    USAGE:
      ./apple-ai-api [options]

    OPTIONS:
      -p, --port PORT       Port to listen on (default: \(Config.port))
      -k, --api-key KEY     Require this API key for all requests
      -d, --debug           Enable debug logging of requests/responses
      -h, --help            Show this help message

    EXAMPLES:
      ./apple-ai-api                          # Start on port 8080
      ./apple-ai-api -p 9090                  # Custom port
      ./apple-ai-api -k sk-my-secret          # Require API key
      ./apple-ai-api -d                       # Debug logging

    ENDPOINTS:
      POST /v1/chat/completions               # Chat completions (OpenAI-compatible)
      GET  /v1/models                         # List available models

    CLIENT EXAMPLE:
      curl http://localhost:8080/v1/chat/completions \\
        -H "Content-Type: application/json" \\
        -d '{"model":"anything","messages":[{"role":"user","content":"Hello!"}]}'

    Or use any OpenAI SDK:
      from openai import OpenAI
      client = OpenAI(base_url="http://localhost:8080/v1", api_key="none")
      r = client.chat.completions.create(model="apple", messages=[{"role":"user","content":"Hi"}])
    """
    print(help)
}

func parseArgs() {
    var args = CommandLine.arguments.dropFirst().makeIterator()
    while let arg = args.next() {
        switch arg {
        case "-h", "--help":
            printHelp()
            exit(0)
        case "-p", "--port":
            guard let val = args.next(), let p = UInt16(val) else {
                fputs("ERROR: --port requires a number\n", stderr)
                exit(1)
            }
            Config.port = p
        case "-k", "--api-key":
            guard let val = args.next(), !val.isEmpty else {
                fputs("ERROR: --api-key requires a value\n", stderr)
                exit(1)
            }
            Config.apiKey = val
        case "-d", "--debug":
            Config.debug = true
        case "--skip-model-check":
            Config.skipModelCheck = true
        default:
            fputs("ERROR: Unknown option: \(arg)\n", stderr)
            printHelp()
            exit(1)
        }
    }
}

// MARK: - Debug logging

func debugLog(_ message: String) {
    if Config.debug {
        let ts = ISO8601DateFormatter().string(from: Date())
        fputs("[DEBUG \(ts)] \(message)\n", stderr)
    }
}

// MARK: - HTTP Server

// AIDEV-NOTE: HTTP server using Network.framework NWListener
// Same pattern as token-counter but handles GET and POST, parses method,
// and routes to OpenAI-compatible endpoints.

class HTTPServer {
    var listener: NWListener?

    func start() {
        guard let nwPort = NWEndpoint.Port(rawValue: Config.port) else {
            fputs("ERROR: Invalid port \(Config.port)\n", stderr)
            exit(1)
        }

        let params = NWParameters.tcp
        params.requiredLocalEndpoint = NWEndpoint.hostPort(host: Config.host, port: nwPort)

        do {
            listener = try NWListener(using: params)
        } catch {
            fputs("ERROR: Failed to create listener: \(error)\n", stderr)
            exit(1)
        }

        listener?.newConnectionHandler = { [weak self] connection in
            self?.handleConnection(connection)
        }

        listener?.stateUpdateHandler = { state in
            switch state {
            case .ready:
                let key = Config.apiKey ?? "none"
                let base = "http://localhost:\(Config.port)"
                let banner = """

                Local FoundationModels
                ======================

                Model:  \(Config.modelId)
                        \(Config.modelName)

                Server: \(base)
                Chat:   \(base)/

                API Settings:
                  Base URL:  \(base)/v1
                  API Key:   \(key)
                  Model:     \(Config.modelId)

                Example:
                  curl \(base)/v1/chat/completions \\
                    -H "Content-Type: application/json" \\
                    -H "Authorization: Bearer \(key)" \\
                    -d '{"model":"\(Config.modelId)","messages":[{"role":"user","content":"Hello!"}]}'

                """
                fputs(banner, stderr)
            case .failed(let error):
                fputs("ERROR: Listener failed: \(error)\n", stderr)
                exit(1)
            default:
                break
            }
        }

        listener?.start(queue: DispatchQueue(label: "http-server"))
    }

    private func handleConnection(_ connection: NWConnection) {
        connection.start(queue: DispatchQueue(label: "http-conn"))
        receiveData(on: connection, accumulated: Data())
    }

    private func receiveData(on connection: NWConnection, accumulated: Data) {
        connection.receive(minimumIncompleteLength: 1, maximumLength: 1_048_576) { [weak self] data, _, isComplete, error in
            guard let self = self else { return }

            var buffer = accumulated
            if let data = data { buffer.append(data) }

            // AIDEV-NOTE: Cap buffer before header parsing completes to prevent
            // unbounded memory accumulation from clients that never send \r\n\r\n
            if buffer.count > Config.maxRequestSize {
                self.sendJSON(connection, status: 413, body: self.errorJSON("Request too large"))
                return
            }

            if let request = self.parseHTTPRequest(buffer) {
                self.route(request: request, connection: connection)
            } else if error != nil || isComplete {
                connection.cancel()
            } else {
                self.receiveData(on: connection, accumulated: buffer)
            }
        }
    }

    // AIDEV-NOTE: HTTP request parser — handles GET and POST with Content-Length framing
    struct HTTPRequest {
        let method: String
        let path: String
        let headers: [(String, String)]
        let body: Data
    }

    private func parseHTTPRequest(_ data: Data) -> HTTPRequest? {
        let separator = Data([0x0D, 0x0A, 0x0D, 0x0A]) // \r\n\r\n
        guard let separatorRange = data.range(of: separator) else { return nil }

        let headerData = data[data.startIndex..<separatorRange.lowerBound]
        guard let headerString = String(data: headerData, encoding: .utf8) else { return nil }

        let headerLines = headerString.components(separatedBy: "\r\n")
        guard let requestLine = headerLines.first else { return nil }

        let parts = requestLine.split(separator: " ", maxSplits: 2)
        guard parts.count >= 2 else { return nil }
        let method = String(parts[0])
        let path = String(parts[1])

        var headers: [(String, String)] = []
        var contentLength = 0
        for line in headerLines.dropFirst() {
            if let colonIndex = line.firstIndex(of: ":") {
                let name = String(line[line.startIndex..<colonIndex]).trimmingCharacters(in: .whitespaces)
                let value = String(line[line.index(after: colonIndex)...]).trimmingCharacters(in: .whitespaces)
                headers.append((name, value))
                if name.lowercased() == "content-length" {
                    contentLength = Int(value) ?? 0
                }
            }
        }

        let bodyStart = separatorRange.upperBound
        let bodyData = data[bodyStart...]
        if method == "POST" && bodyData.count < contentLength { return nil } // need more data

        return HTTPRequest(
            method: method,
            path: path,
            headers: headers,
            body: Data(bodyData.prefix(contentLength))
        )
    }

    // MARK: - Routing

    private func route(request: HTTPRequest, connection: NWConnection) {
        debugLog("\(request.method) \(request.path)")
        if Config.debug && !request.body.isEmpty {
            if let bodyStr = String(data: request.body, encoding: .utf8) {
                debugLog("Request body: \(bodyStr)")
            }
        }

        // CORS preflight
        if request.method == "OPTIONS" {
            sendCORS(connection)
            return
        }

        // Auth check
        if let requiredKey = Config.apiKey {
            let authHeader = request.headers.first(where: { $0.0.lowercased() == "authorization" })?.1 ?? ""
            let providedKey = authHeader.lowercased().hasPrefix("bearer ") ? String(authHeader.dropFirst(7)) : ""
            if providedKey != requiredKey {
                sendJSON(connection, status: 401, body: errorJSON("Invalid API key"))
                return
            }
        }

        let path = request.path.split(separator: "?").first.map(String.init) ?? request.path

        switch (request.method, path) {
        case ("GET", "/v1/models"):
            handleModels(connection)
        case ("POST", "/v1/chat/completions"):
            handleChatCompletions(request: request, connection: connection)
        case ("GET", "/"):
            handleIndex(connection)
        default:
            sendJSON(connection, status: 404, body: errorJSON("Unknown endpoint: \(request.method) \(path)"))
        }
    }

    // MARK: - /v1/models

    // AIDEV-TODO: Explore SystemLanguageModel API for capability introspection
    private func handleModels(_ connection: NWConnection) {
        let response: [String: Any] = [
            "object": "list",
            "data": [
                [
                    "id": Config.modelId,
                    "object": "model",
                    "created": Int(Date().timeIntervalSince1970),
                    "owned_by": "apple",
                    "name": Config.modelName,
                ]
            ]
        ]
        sendJSON(connection, status: 200, body: response)
    }

    // MARK: - /v1/chat/completions

    // AIDEV-NOTE: Chat completions handler — maps OpenAI message format to FoundationModels sessions.
    // Creates a fresh session per request. System messages become the session instruction.
    // Multi-turn is replayed by sending prior assistant/user messages sequentially.
    private func handleChatCompletions(request: HTTPRequest, connection: NWConnection) {
        guard let json = try? JSONSerialization.jsonObject(with: request.body) as? [String: Any],
              let messages = json["messages"] as? [[String: Any]] else {
            sendJSON(connection, status: 400, body: errorJSON("Invalid request: 'messages' array required"))
            return
        }

        let maxTokens = json["max_tokens"] as? Int ?? json["max_completion_tokens"] as? Int
        let stream = json["stream"] as? Bool ?? false

        // Extract system prompt and conversation messages
        let parsed = Self.parseMessages(messages)

        guard !parsed.conversation.isEmpty else {
            sendJSON(connection, status: 400, body: errorJSON("No user/assistant messages provided"))
            return
        }

        guard let lastIdx = parsed.conversation.lastIndex(where: { $0.role == "user" }) else {
            sendJSON(connection, status: 400, body: errorJSON("No user message found"))
            return
        }

        if stream {
            handleStreamingCompletion(
                systemPrompt: parsed.system, conversation: parsed.conversation,
                lastIdx: lastIdx, maxTokens: maxTokens, connection: connection
            )
        } else {
            handleNonStreamingCompletion(
                systemPrompt: parsed.system, conversation: parsed.conversation,
                lastIdx: lastIdx, maxTokens: maxTokens, connection: connection
            )
        }
    }

    // AIDEV-NOTE: Message parsing — handles string content and array-of-parts content format
    private static func parseMessages(_ messages: [[String: Any]]) -> (system: String?, conversation: [(role: String, content: String)]) {
        var systemPrompt: String? = nil
        var conversationMessages: [(role: String, content: String)] = []

        for msg in messages {
            guard let role = msg["role"] as? String else { continue }
            let content: String
            if let s = msg["content"] as? String {
                content = s
            } else if let parts = msg["content"] as? [[String: Any]] {
                content = parts.compactMap { part -> String? in
                    if part["type"] as? String == "text" {
                        return part["text"] as? String
                    }
                    return nil
                }.joined(separator: "\n")
            } else {
                continue
            }

            if role == "system" {
                systemPrompt = content
            } else {
                conversationMessages.append((role: role, content: content))
            }
        }
        return (systemPrompt, conversationMessages)
    }

    // AIDEV-NOTE: For multi-turn, we replay prior turns via respond() calls.
    // This is somewhat wasteful but the simplest correct approach — each prior
    // user message gets a respond() call so the session builds up history.
    private func replayHistory(
        session: LanguageModelSession,
        conversation: [(role: String, content: String)],
        upTo lastIdx: Int,
        maxTokens: Int?
    ) async throws {
        for i in 0..<lastIdx {
            let msg = conversation[i]
            if msg.role == "user" {
                var options = GenerationOptions()
                if let maxTokens = maxTokens {
                    options = GenerationOptions(maximumResponseTokens: maxTokens)
                }
                let _ = try await session.respond(to: msg.content, options: options)
            }
        }
    }

    private func makeSession(systemPrompt: String?) -> LanguageModelSession {
        if let systemPrompt = systemPrompt {
            return LanguageModelSession() { systemPrompt }
        } else {
            return LanguageModelSession()
        }
    }

    private func handleNonStreamingCompletion(
        systemPrompt: String?,
        conversation: [(role: String, content: String)],
        lastIdx: Int,
        maxTokens: Int?,
        connection: NWConnection
    ) {
        Task {
            do {
                let session = makeSession(systemPrompt: systemPrompt)
                try await replayHistory(session: session, conversation: conversation, upTo: lastIdx, maxTokens: maxTokens)

                var options = GenerationOptions()
                if let maxTokens = maxTokens {
                    options = GenerationOptions(maximumResponseTokens: maxTokens)
                }
                let response = try await session.respond(to: conversation[lastIdx].content, options: options)
                let responseText = response.content

                debugLog("Response: \(responseText)")

                let completionId = "chatcmpl-\(UUID().uuidString.prefix(12))"
                let result: [String: Any] = [
                    "id": completionId,
                    "object": "chat.completion",
                    "created": Int(Date().timeIntervalSince1970),
                    "model": Config.modelId,
                    "choices": [
                        [
                            "index": 0,
                            "message": [
                                "role": "assistant",
                                "content": responseText,
                            ],
                            "finish_reason": "stop",
                        ]
                    ],
                    "usage": [
                        "prompt_tokens": 0,    // AIDEV-TODO: Get actual token counts if API exposes them
                        "completion_tokens": 0,
                        "total_tokens": 0,
                    ],
                ]

                self.sendJSON(connection, status: 200, body: result)
            } catch {
                fputs("ERROR: Generation failed: \(error)\n", stderr)
                self.sendJSON(connection, status: 500, body: self.errorJSON("Generation failed: \(error.localizedDescription)"))
            }
        }
    }

    // AIDEV-NOTE: SSE streaming implementation.
    // Apple's ResponseStream<String> yields cumulative snapshots (not deltas),
    // so we track previousLength and slice out the new characters for each SSE chunk.
    // Format follows OpenAI's streaming protocol: each chunk is a "data: {json}\n\n" line
    // with a final "data: [DONE]\n\n" sentinel.
    private func handleStreamingCompletion(
        systemPrompt: String?,
        conversation: [(role: String, content: String)],
        lastIdx: Int,
        maxTokens: Int?,
        connection: NWConnection
    ) {
        Task {
            do {
                let session = makeSession(systemPrompt: systemPrompt)
                try await replayHistory(session: session, conversation: conversation, upTo: lastIdx, maxTokens: maxTokens)

                var options = GenerationOptions()
                if let maxTokens = maxTokens {
                    options = GenerationOptions(maximumResponseTokens: maxTokens)
                }

                let completionId = "chatcmpl-\(UUID().uuidString.prefix(12))"
                let created = Int(Date().timeIntervalSince1970)

                // Send SSE headers
                let header = "HTTP/1.1 200 OK\r\n" +
                    "Content-Type: text/event-stream\r\n" +
                    "Cache-Control: no-cache\r\n" +
                    "Access-Control-Allow-Origin: *\r\n" +
                    "Access-Control-Allow-Headers: Content-Type, Authorization\r\n" +
                    "Connection: keep-alive\r\n" +
                    "\r\n"
                guard let headerData = header.data(using: .utf8) else {
                    connection.cancel()
                    return
                }
                self.sendRaw(connection, data: headerData)

                let stream = session.streamResponse(to: conversation[lastIdx].content, options: options)
                var previousLength = 0

                for try await snapshot in stream {
                    let text = snapshot.content
                    let newContent = String(text.dropFirst(previousLength))
                    previousLength = text.count

                    if !newContent.isEmpty {
                        let chunk: [String: Any] = [
                            "id": completionId,
                            "object": "chat.completion.chunk",
                            "created": created,
                            "model": Config.modelId,
                            "choices": [
                                [
                                    "index": 0,
                                    "delta": ["content": newContent],
                                    "finish_reason": NSNull(),
                                ]
                            ],
                        ]
                        if let jsonData = try? JSONSerialization.data(withJSONObject: chunk),
                           let jsonStr = String(data: jsonData, encoding: .utf8),
                           let sseData = "data: \(jsonStr)\n\n".data(using: .utf8) {
                            debugLog("Stream chunk: \(newContent)")
                            self.sendRaw(connection, data: sseData)
                        }
                    }
                }

                // Send final chunk with finish_reason
                let finalChunk: [String: Any] = [
                    "id": completionId,
                    "object": "chat.completion.chunk",
                    "created": created,
                    "model": Config.modelId,
                    "choices": [
                        [
                            "index": 0,
                            "delta": [String: String](),
                            "finish_reason": "stop",
                        ]
                    ],
                ]
                if let jsonData = try? JSONSerialization.data(withJSONObject: finalChunk),
                   let jsonStr = String(data: jsonData, encoding: .utf8),
                   let sseData = "data: \(jsonStr)\n\n".data(using: .utf8) {
                    self.sendRaw(connection, data: sseData)
                }

                // Send done sentinel and close
                if let doneData = "data: [DONE]\n\n".data(using: .utf8) {
                    self.sendRaw(connection, data: doneData) {
                        connection.cancel()
                    }
                } else {
                    connection.cancel()
                }
            } catch {
                fputs("ERROR: Streaming generation failed: \(error)\n", stderr)
                let errChunk = "data: {\"error\":{\"message\":\"\(error.localizedDescription)\"}}\n\n"
                if let errData = errChunk.data(using: .utf8) {
                    self.sendRaw(connection, data: errData) {
                        connection.cancel()
                    }
                } else {
                    connection.cancel()
                }
            }
        }
    }

    private func sendRaw(_ connection: NWConnection, data: Data, then: (() -> Void)? = nil) {
        connection.send(content: data, completion: .contentProcessed { _ in
            then?()
        })
    }

