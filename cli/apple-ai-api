    // AIDEV-NOTE: Self-contained chat UI with streaming support.
    // Uses SSE via fetch() + ReadableStream to display tokens as they arrive.
    // No external dependencies — pure HTML/CSS/JS inlined in the Swift binary.
    private func handleIndex(_ connection: NWConnection) {
        let html = chatHTML()
        guard let body = html.data(using: .utf8) else {
            sendJSON(connection, status: 500, body: errorJSON("Failed to encode HTML"))
            return
        }
        sendHTTP(connection, status: 200, contentType: "text/html; charset=utf-8", body: body)
    }

