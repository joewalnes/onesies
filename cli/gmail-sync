def parse_since(value):
    """Parse --since value into a datetime. Supports: 7d, 3mo, 2y, 2020-01-01."""
    if value is None:
        return None
    m = re.match(r'^(\d+)(d|w|mo|y)$', value)
    if m:
        n, unit = int(m.group(1)), m.group(2)
        now = datetime.datetime.now(datetime.timezone.utc)
        if unit == 'd':
            return now - datetime.timedelta(days=n)
        elif unit == 'w':
            return now - datetime.timedelta(weeks=n)
        elif unit == 'mo':
            return now - datetime.timedelta(days=n * 30)
        elif unit == 'y':
            return now - datetime.timedelta(days=n * 365)
    # Try ISO date
    try:
        dt = datetime.datetime.fromisoformat(value)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=datetime.timezone.utc)
        return dt
    except ValueError:
        pass
    raise argparse.ArgumentTypeError(f"Invalid --since value: {value!r}. Use e.g. 7d, 3mo, 2y, 2020-01-01")


def parse_args():
    parser = argparse.ArgumentParser(
        prog="gmail-sync",
        description="Sync Gmail to a local SQLite database.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=textwrap.dedent("""\
            examples:
              gmail-sync mail.db                          # sync last 30 days
              gmail-sync mail.db --all                    # sync everything
              gmail-sync mail.db --since 7d               # last 7 days
              gmail-sync mail.db --since 3mo              # last 3 months
              gmail-sync mail.db --since 2020-01-01       # since a specific date
              gmail-sync mail.db --watch                  # keep polling for new mail
              gmail-sync mail.db --label INBOX             # only inbox
              gmail-sync mail.db --from boss@co.com       # only from specific sender
              gmail-sync mail.db --query "has:attachment"  # Gmail search query
              gmail-sync mail.db --attachments "*.pdf"     # download PDF attachments
              gmail-sync mail.db --attachments "*.pdf,*.csv" --since 1y
              gmail-sync mail.db --fetch-attachments "*.pdf" --since 1y  # lazy download

            attachment auto-download:
              Attachments under 100KB are always downloaded (inline images, small
              receipts). Override with --auto-download-size. Use --attachments for
              selective download by pattern, or --fetch-attachments to retroactively
              download attachments for messages already in the database.
        """),
    )

    # Subcommands: default is "sync", but "fetch-attachments" is a separate mode
    parser.add_argument("db", help="Path to SQLite database file (created if missing)")
    parser.add_argument("--credentials", default=None,
                        help="Path to OAuth2 credentials.json (default: ~/.config/gmail-sync/credentials.json)")
    parser.add_argument("-V", "--version", action="version", version=f"%(prog)s {VERSION}")

    time_group = parser.add_mutually_exclusive_group()
    time_group.add_argument("--since", type=parse_since, default=None,
                            help="How far back to sync (e.g. 7d, 3mo, 2y, 2020-01-01)")
    time_group.add_argument("--all", action="store_true", help="Sync all messages")

    parser.add_argument("--watch", action="store_true", help="Keep running, poll for new messages")
    parser.add_argument("--label", action="append", default=[], help="Filter by label (repeatable)")
    parser.add_argument("--from", dest="from_addr", action="append", default=[],
                        help="Filter by sender (repeatable)")
    parser.add_argument("--query", default=None, help="Gmail search query (passthrough)")
    parser.add_argument("--attachments", default=None,
                        help='Download attachments matching glob pattern during sync (e.g. "*.pdf,*.csv", "*" for all)')
    parser.add_argument("--fetch-attachments", default=None, dest="fetch_attachments",
                        help='Retroactively download attachments matching pattern from already-synced messages')
    parser.add_argument("--auto-download-size", type=int, default=AUTO_DOWNLOAD_SIZE,
                        help=f"Auto-download attachments smaller than this in bytes (default: {AUTO_DOWNLOAD_SIZE})")
    parser.add_argument("--quiet", action="store_true", help="Suppress all output except errors")

    args = parser.parse_args()

    # Default to 30 days if neither --since nor --all specified
    if not args.all and args.since is None and not args.fetch_attachments:
        args.since = parse_since(DEFAULT_SINCE)

    return args

