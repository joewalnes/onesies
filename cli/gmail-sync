def authenticate(credentials_path, output):
    """Authenticate with Gmail API via OAuth2. Returns a Gmail service object."""
    config_dir = os.path.expanduser("~/.config/gmail-sync")
    os.makedirs(config_dir, exist_ok=True)
    stored_creds = os.path.join(config_dir, "credentials.json")
    token_path = os.path.join(config_dir, "token.json")

    creds = None

    # Try loading existing token
    if os.path.exists(token_path):
        try:
            creds = Credentials.from_authorized_user_file(token_path, GMAIL_SCOPES)
        except Exception:
            output.warn("Stored token is invalid, re-authenticating...")
            creds = None

    # Refresh or re-auth
    if creds and creds.expired and creds.refresh_token:
        try:
            creds.refresh(Request())
            with open(token_path, "w") as f:
                f.write(creds.to_json())
        except Exception:
            output.warn("Token refresh failed, re-authenticating...")
            creds = None

    if not creds or not creds.valid:
        # Find credentials.json
        creds_file = None
        if credentials_path and os.path.exists(credentials_path):
            creds_file = credentials_path
            # Copy to config dir for future use
            if os.path.abspath(credentials_path) != os.path.abspath(stored_creds):
                import shutil
                shutil.copy2(credentials_path, stored_creds)
                output.info(f"Credentials saved to {stored_creds}")
        elif os.path.exists(stored_creds):
            creds_file = stored_creds
        elif credentials_path:
            output.error(f"Credentials file not found: {credentials_path}")
            sys.exit(1)

        if not creds_file:
            output.error("No credentials file found.")
            print(AUTH_GUIDE, file=sys.stderr)
            sys.exit(1)

        output.info("Opening browser for Google sign-in...")
        flow = InstalledAppFlow.from_client_secrets_file(creds_file, GMAIL_SCOPES)
        creds = flow.run_local_server(port=0)

        with open(token_path, "w") as f:
            f.write(creds.to_json())
        output.success("Authentication successful, token saved.")

    return build("gmail", "v1", credentials=creds)

