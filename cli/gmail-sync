# AIDEV-NOTE: FTS triggers keep the full-text index in sync with the messages
# table automatically on INSERT, UPDATE, and DELETE. The content-sync approach
# means FTS reads from the messages table on demand, keeping storage efficient.
FTS_SQL = """\
CREATE VIRTUAL TABLE IF NOT EXISTS messages_fts USING fts5(
    subject, body_text, sender, recipient,
    content='messages',
    content_rowid='rowid'
);

CREATE TRIGGER IF NOT EXISTS messages_fts_insert AFTER INSERT ON messages BEGIN
    INSERT INTO messages_fts(rowid, subject, body_text, sender, recipient)
    VALUES (new.rowid, new.subject, new.body_text, new.sender, new.recipient);
END;

CREATE TRIGGER IF NOT EXISTS messages_fts_delete AFTER DELETE ON messages BEGIN
    INSERT INTO messages_fts(messages_fts, rowid, subject, body_text, sender, recipient)
    VALUES ('delete', old.rowid, old.subject, old.body_text, old.sender, old.recipient);
END;

CREATE TRIGGER IF NOT EXISTS messages_fts_update AFTER UPDATE ON messages BEGIN
    INSERT INTO messages_fts(messages_fts, rowid, subject, body_text, sender, recipient)
    VALUES ('delete', old.rowid, old.subject, old.body_text, old.sender, old.recipient);
    INSERT INTO messages_fts(rowid, subject, body_text, sender, recipient)
    VALUES (new.rowid, new.subject, new.body_text, new.sender, new.recipient);
END;
"""


