class Output:
    """Handles progress output: colored for TTY, plain for pipes, silent for --quiet."""

    def __init__(self, quiet=False):
        self.quiet = quiet
        self.is_tty = sys.stderr.isatty()

    def _write(self, msg, color=None):
        if self.quiet:
            return
        if self.is_tty and color:
            codes = {"red": "31", "green": "32", "yellow": "33", "blue": "34", "dim": "90"}
            sys.stderr.write(f"\033[{codes.get(color, '0')}m{msg}\033[0m\n")
        else:
            sys.stderr.write(f"{msg}\n")
        sys.stderr.flush()

    def info(self, msg):
        self._write(msg)

    def success(self, msg):
        self._write(f"✓ {msg}" if self.is_tty else msg, "green")

    def warn(self, msg):
        self._write(f"⚠ {msg}" if self.is_tty else f"WARN: {msg}", "yellow")

    def error(self, msg):
        self._write(f"✗ {msg}" if self.is_tty else f"ERROR: {msg}", "red")

    def progress(self, msg):
        """Overwriting progress line for TTY, regular line for pipes."""
        if self.quiet:
            return
        if self.is_tty:
            sys.stderr.write(f"\033[34m{msg}\033[0m\r")
            sys.stderr.flush()
        else:
            sys.stderr.write(f"{msg}\n")
            sys.stderr.flush()

    def progress_done(self):
        """Clear the progress line on TTY."""
        if self.is_tty and not self.quiet:
            sys.stderr.write("\033[2K\r")
            sys.stderr.flush()

