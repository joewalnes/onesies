def resolve_provider_key(provider_name):
    """Search for API key in provider-specific env vars, key files, or default."""
    prov = PROVIDERS.get(provider_name)
    if not prov:
        return None
    # Check env vars
    for env_var in prov["key_env"]:
        val = os.environ.get(env_var)
        if val:
            return val
    # Check key files
    for path in prov["key_files"]:
        expanded = os.path.expanduser(path)
        if os.path.exists(expanded):
            try:
                with open(expanded) as f:
                    key = f.read().strip()
                if key:
                    return key
            except IOError:
                pass
    # Fall back to provider default key (e.g. "public" for opencode)
    if "default_key" in prov:
        return prov["default_key"]
    return None

# ─── ANSI & Terminal ────────────────────────────────────────────────────────

class C:
    """ANSI color/style codes."""
    RESET = "\033[0m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    ITALIC = "\033[3m"
    UNDERLINE = "\033[4m"
    # Colors
    RED = "\033[31m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    BLUE = "\033[34m"
    MAGENTA = "\033[35m"
    CYAN = "\033[36m"
    WHITE = "\033[37m"
    GRAY = "\033[90m"
    # Bright
    BRIGHT_GREEN = "\033[92m"
    BRIGHT_CYAN = "\033[96m"
    BRIGHT_YELLOW = "\033[93m"
    BRIGHT_MAGENTA = "\033[95m"


def supports_color():
    """Check if terminal supports color output."""
    if os.environ.get("NO_COLOR"):
        return False
    if os.environ.get("FORCE_COLOR"):
        return True
    return hasattr(sys.stdout, "isatty") and sys.stdout.isatty()


def detect_terminal():
    """Detect terminal capabilities."""
    term = os.environ.get("TERM", "")
    term_program = os.environ.get("TERM_PROGRAM", "")
    caps = {
        "color": supports_color(),
        "kitty_images": "kitty" in term_program.lower() or "kitty" in term.lower(),
        "iterm_images": term_program == "iTerm.app" or "iterm" in term_program.lower(),
        "ghostty_images": "ghostty" in term_program.lower(),
        "sixel": False,  # Would need to query terminal
        "bracketed_paste": True,  # Most modern terminals
        "unicode": True,  # Assume modern terminal
        "nerd_fonts": True,  # Assume available, degrade gracefully
    }
    caps["images"] = caps["kitty_images"] or caps["iterm_images"] or caps["ghostty_images"]
    return caps


