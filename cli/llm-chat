def cmd_model(session, args):
    """Switch model."""
    if args:
        session.client.model = args.strip()
        print(f"  {Icons.CHECK}Model set to {styled(session.client.model, C.BOLD)}")
        return

    models = session.client.list_models()
    if not models:
        print(f"  {Icons.WARN}No models available")
        return

    print(f"\n  {bold('Available Models')}")
    for i, m in enumerate(models, 1):
        marker = styled(" ●", C.GREEN) if m == session.client.model else "  "
        print(f"  {marker} {styled(str(i), C.DIM)}) {m}")
    print()

    try:
        choice = input(dim("  Select model (number or name): ")).strip()
    except (EOFError, KeyboardInterrupt):
        print()
        return

    if choice.isdigit():
        idx = int(choice) - 1
        if 0 <= idx < len(models):
            session.client.model = models[idx]
        else:
            print(f"  {Icons.WARN}Invalid selection")
            return
    elif choice in models:
        session.client.model = choice
    else:
        # Fuzzy match
        matches = [m for m in models if choice.lower() in m.lower()]
        if len(matches) == 1:
            session.client.model = matches[0]
        elif matches:
            print(f"  {Icons.WARN}Ambiguous: {', '.join(matches[:5])}")
            return
        else:
            print(f"  {Icons.WARN}Model not found: {choice}")
            return

    print(f"  {Icons.CHECK}Switched to {styled(session.client.model, C.BOLD)}")


def cmd_models(session, args):
    """List models."""
    models = session.client.list_models()
    if not models:
        print(f"  {Icons.WARN}No models available")
        return
    print(f"\n  {bold('Models')} ({len(models)} available)")
    for m in models:
        marker = styled("● ", C.GREEN) if m == session.client.model else "  "
        print(f"  {marker}{m}")
    print()


def cmd_system(session, args):
    """Set or show system prompt."""
    if args:
        session.set_system(args.strip())
        print(f"  {Icons.CHECK}System prompt set ({len(args.strip())} chars)")
    elif session.system_prompt:
        print(f"  {bold('System prompt:')}")
        print(f"  {dim(session.system_prompt[:200])}")
        if len(session.system_prompt) > 200:
            print(dim(f"  ... ({len(session.system_prompt)} chars total)"))
    else:
        print(f"  {dim('No system prompt set. Usage: /system <your prompt>')}")


def cmd_clear(session, args):
    """Clear conversation history."""
    session.messages.clear()
    session.turn_count = 0
    session.last_response = ""
    session.attached_files.clear()
    print(f"  {Icons.CHECK}Conversation cleared")


def cmd_retry(session, args):
    """Regenerate last response."""
    if len(session.messages) < 2:
        print(f"  {Icons.WARN}Nothing to retry")
        return
    # Remove last assistant message
    if session.messages[-1]["role"] == "assistant":
        session.messages.pop()
    session.turn_count -= 1
    session.stream_response()


def cmd_copy(session, args):
    """Copy last response to clipboard."""
    if not session.last_response:
        print(f"  {Icons.WARN}No response to copy")
        return
    try:
        if sys.platform == "darwin":
            proc = subprocess.Popen(["pbcopy"], stdin=subprocess.PIPE)
        else:
            proc = subprocess.Popen(["xclip", "-selection", "clipboard"], stdin=subprocess.PIPE)
        proc.communicate(session.last_response.encode())
        print(f"  {Icons.CLIP}Copied to clipboard ({len(session.last_response)} chars)")
    except FileNotFoundError:
        print(f"  {Icons.WARN}Clipboard tool not found (need pbcopy or xclip)")


def cmd_attach(session, args):
    """Attach a file to the next message."""
    if not args:
        print(f"  {dim('Usage: /attach <filepath>')}")
        if session.attached_files:
            print(f"  {bold('Pending attachments:')}")
            for f in session.attached_files:
                print(f"    {Icons.FILE}{os.path.basename(f)}")
        return

    path = os.path.expanduser(args.strip().strip("'\""))
    if not os.path.exists(path):
        print(f"  {Icons.WARN}File not found: {path}")
        return

    image_exts = {".png", ".jpg", ".jpeg", ".gif", ".webp"}
    ext = os.path.splitext(path)[1].lower()
    if ext in image_exts:
        session.attached_files.append(path)
        print(f"  {Icons.IMAGE}Image queued: {os.path.basename(path)} (will send with next message)")
    else:
        # Read text file and include in message
        try:
            with open(path) as f:
                content = f.read()
            session.attached_files.append(None)  # Marker
            # Store as pending text
            if not hasattr(session, '_pending_text_files'):
                session._pending_text_files = []
            session._pending_text_files.append((os.path.basename(path), content))
            print(f"  {Icons.FILE}File queued: {os.path.basename(path)} ({len(content)} chars, will include with next message)")
        except Exception as e:
            print(f"  {Icons.WARN}Error reading file: {e}")


def cmd_save(session, args):
    """Save conversation to file."""
    filename = args.strip() if args else f"chat-{int(time.time())}.md"
    try:
        with open(filename, "w") as f:
            f.write(f"# Chat Export\n")
            f.write(f"Model: {session.client.model}\n")
            f.write(f"Date: {time.strftime('%Y-%m-%d %H:%M:%S')}\n\n---\n\n")
            for msg in session.messages:
                role = "**You**" if msg["role"] == "user" else "**Assistant**"
                content = msg["content"] if isinstance(msg["content"], str) else "[multimodal]"
                f.write(f"{role}:\n{content}\n\n---\n\n")
        print(f"  {Icons.CHECK}Saved to {styled(filename, C.UNDERLINE)}")
    except Exception as e:
        print(f"  {Icons.WARN}Error saving: {e}")


def cmd_info(session, args):
    """Show session info."""
    tokens = session.client.total_tokens
    total = tokens["prompt"] + tokens["completion"]
    print(f"""
  {bold("Session Info")}
  {dim("Model:")}       {session.client.model or 'none'}
  {dim("Base URL:")}    {session.client.base_url}
  {dim("Turns:")}       {session.turn_count}
  {dim("Messages:")}    {len(session.messages)}
  {dim("Tokens:")}      {total:,} total ({tokens['prompt']:,} in / {tokens['completion']:,} out)
  {dim("System:")}      {'set' if session.system_prompt else 'none'}
  {dim("Terminal:")}     {'images' if TERM_CAPS['images'] else 'text only'}
  {dim("Attachments:")} {len(session.attached_files)} pending
""")


def cmd_quit(session, args):
    """Exit the chat."""
    print(f"\n  {dim('Goodbye!')}")
    sys.exit(0)


COMMANDS = {
    "help": cmd_help, "h": cmd_help, "?": cmd_help,
    "model": cmd_model,
    "models": cmd_models,
    "system": cmd_system,
    "clear": cmd_clear,
    "retry": cmd_retry,
    "copy": cmd_copy,
    "attach": cmd_attach,
    "save": cmd_save,
    "info": cmd_info,
    "quit": cmd_quit, "q": cmd_quit, "exit": cmd_quit,
}

# ─── Readline & Editor Integration ─────────────────────────────────────────

def setup_readline():
    """Configure readline with history and keybindings."""
    os.makedirs(CONFIG_DIR, exist_ok=True)
    if os.path.exists(HISTORY_FILE):
        readline.read_history_file(HISTORY_FILE)
    readline.set_history_length(MAX_HISTORY)

    # Enable Ctrl+X Ctrl+E to open $EDITOR (like bash)
    # This is handled in the input loop since readline doesn't support it natively in Python
    readline.parse_and_bind("set editing-mode emacs")
    readline.parse_and_bind("set show-all-if-ambiguous on")


def save_readline_history():
    """Save readline history on exit."""
    try:
        readline.write_history_file(HISTORY_FILE)
    except Exception:
        pass


def open_in_editor(initial_text=""):
    """Open text in $EDITOR and return edited content."""
    editor = os.environ.get("EDITOR", os.environ.get("VISUAL", "vi"))
    with tempfile.NamedTemporaryFile(mode="w", suffix=".md", delete=False) as f:
        f.write(initial_text)
        tmpfile = f.name
    try:
        ret = subprocess.call([editor, tmpfile])
        if ret == 0:
            with open(tmpfile) as f:
                return f.read()
    except Exception as e:
        print(f"  {Icons.WARN}Editor error: {e}")
    finally:
        os.unlink(tmpfile)
    return None


