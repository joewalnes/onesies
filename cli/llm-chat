# ─── API Client ─────────────────────────────────────────────────────────────

class LLMClient:
    """HTTP client for OpenAI-compatible chat completions API."""

    def __init__(self, base_url, api_key=None):
        self.base_url = base_url.rstrip("/")
        self.api_key = api_key
        self.model = None
        self.models_cache = None
        self.total_tokens = {"prompt": 0, "completion": 0}

    def _headers(self):
        h = {"Content-Type": "application/json"}
        if self.api_key:
            h["Authorization"] = f"Bearer {self.api_key}"
        return h

    def _request(self, path, data=None, stream=False):
        """Make HTTP request to API."""
        url = f"{self.base_url}{path}"
        body = json.dumps(data).encode() if data else None
        req = Request(url, data=body, headers=self._headers(), method="POST" if data else "GET")
        return urlopen(req, timeout=READ_TIMEOUT if stream else CONNECT_TIMEOUT)

    def test_connection(self):
        """Test if we can connect to the API. Returns (success, error_message)."""
        try:
            self._request("/models")
            return True, None
        except HTTPError as e:
            if e.code == 401:
                return False, "unauthorized"
            return False, f"HTTP {e.code}: {e.reason}"
        except URLError as e:
            return False, f"Connection failed: {e.reason}"
        except Exception as e:
            return False, str(e)

    def list_models(self):
        """Fetch available models."""
        if self.models_cache:
            return self.models_cache
        try:
            resp = self._request("/models")
            data = json.loads(resp.read().decode())
            models = [m["id"] for m in data.get("data", [])]
            models.sort()
            self.models_cache = models
            return models
        except Exception:
            return []

    def chat_stream(self, messages):
        """Send chat request and yield response chunks."""
        data = {
            "model": self.model,
            "messages": messages,
            "stream": True,
        }
        try:
            resp = self._request("/chat/completions", data=data, stream=True)
        except HTTPError as e:
            body = e.read().decode()
            try:
                err = json.loads(body)
                yield {"error": err.get("error", {}).get("message", body)}
            except json.JSONDecodeError:
                yield {"error": f"HTTP {e.code}: {body[:200]}"}
            return
        except Exception as e:
            yield {"error": str(e)}
            return

        # Parse SSE stream
        buffer = ""
        for raw_line in resp:
            line = raw_line.decode("utf-8", errors="replace")
            buffer += line
            while "\n" in buffer:
                sse_line, buffer = buffer.split("\n", 1)
                sse_line = sse_line.rstrip("\r")
                if sse_line.startswith("data: "):
                    payload = sse_line[6:]
                    if payload.strip() == "[DONE]":
                        return
                    try:
                        chunk = json.loads(payload)
                        delta = chunk.get("choices", [{}])[0].get("delta", {})
                        if "content" in delta:
                            yield {"content": delta["content"]}
                        # Capture usage if present (some APIs send on last chunk)
                        usage = chunk.get("usage")
                        if usage:
                            yield {"usage": usage}
                    except json.JSONDecodeError:
                        continue


# ─── Chat Session ───────────────────────────────────────────────────────────

class ChatSession:
    """Manages conversation state and interaction."""

    def __init__(self, client):
        self.client = client
        self.messages = []
        self.system_prompt = None
        self.turn_count = 0
        self.last_response = ""
        self.attached_files = []  # Pending file attachments
        self.tips_shown = set()

    def set_system(self, prompt):
        self.system_prompt = prompt

    def build_messages(self):
        """Build message list for API, including system prompt."""
        msgs = []
        if self.system_prompt:
            msgs.append({"role": "system", "content": self.system_prompt})
        # Truncate if too long
        history = self.messages
        if len(history) > MAX_CONTEXT_MESSAGES * 2:
            history = history[-(MAX_CONTEXT_MESSAGES * 2):]
            if not self._tip_shown("truncate"):
                print(dim(f"  {Icons.INFO}Context trimmed to last {MAX_CONTEXT_MESSAGES} exchanges"))
        msgs.extend(history)
        return msgs

    def _tip_shown(self, key):
        if key in self.tips_shown:
            return True
        self.tips_shown.add(key)
        return False

    def add_user_message(self, text):
        """Add user message, possibly with image attachments."""
        if self.attached_files:
            # Build multimodal content
            content = [{"type": "text", "text": text}]
            for f in self.attached_files:
                content.append(encode_image_for_api(f))
                print(dim(f"  {Icons.IMAGE}Attached: {os.path.basename(f)}"))
            self.messages.append({"role": "user", "content": content})
            self.attached_files = []
        else:
            self.messages.append({"role": "user", "content": text})

    def stream_response(self):
        """Stream assistant response to terminal."""
        msgs = self.build_messages()
        spinner = Spinner("Thinking")
        spinner.start()

        full_response = ""
        first_token = True
        error_msg = None

        for chunk in self.client.chat_stream(msgs):
            if "error" in chunk:
                spinner.stop()
                error_msg = chunk["error"]
                break
            if "content" in chunk:
                if first_token:
                    spinner.stop()
                    # Print assistant header
                    sys.stdout.write(f"{styled(Icons.ROBOT, C.BRIGHT_GREEN)}")
                    first_token = False
                sys.stdout.write(chunk["content"])
                sys.stdout.flush()
                full_response += chunk["content"]
            if "usage" in chunk:
                usage = chunk["usage"]
                self.client.total_tokens["prompt"] += usage.get("prompt_tokens", 0)
                self.client.total_tokens["completion"] += usage.get("completion_tokens", 0)

        if error_msg:
            print(f"\n{styled(Icons.WARN + 'Error: ', C.RED)}{error_msg}")
            return

        if first_token:
            spinner.stop()
            print(dim("  (empty response)"))
            return

        # Ensure newline after response
        if full_response and not full_response.endswith("\n"):
            sys.stdout.write("\n")

        self.messages.append({"role": "assistant", "content": full_response})
        self.last_response = full_response
        self.turn_count += 1
        self._show_contextual_tip()

    def _show_contextual_tip(self):
        """Show helpful tips based on usage patterns."""
        tips = []
        if self.turn_count == 1 and not self._tip_shown("first"):
            tips.append(f"Tip: {styled('/help', C.CYAN)} lists all commands  {dim('│')}  {styled('Ctrl+X Ctrl+E', C.CYAN)} opens $EDITOR  {dim('│')}  {styled('Ctrl+C', C.CYAN)} to exit")
        elif self.turn_count == 3 and not self._tip_shown("slash"):
            tips.append(f"Tip: {styled('/retry', C.CYAN)} regenerates  {dim('│')}  {styled('/copy', C.CYAN)} copies last response  {dim('│')}  {styled('/clear', C.CYAN)} resets")
        elif self.turn_count == 5 and not self._tip_shown("attach"):
            if TERM_CAPS["images"]:
                tips.append(f"Tip: {styled('/attach <path>', C.CYAN)} to include images  {dim('│')}  paste file paths to attach")
            else:
                tips.append(f"Tip: {styled('/attach <path>', C.CYAN)} to include files in your message")
        elif self.turn_count == 8 and not self._tip_shown("system"):
            tips.append(f"Tip: {styled('/system <prompt>', C.CYAN)} sets a system prompt  {dim('│')}  {styled('/save', C.CYAN)} exports the conversation")
        if tips:
            print(dim(tips[0]))


