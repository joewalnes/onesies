# ─── Utilities ──────────────────────────────────────────────────────────────

def styled(text, *styles):
    """Apply ANSI styles to text."""
    if not TERM_CAPS["color"]:
        return text
    prefix = "".join(styles)
    return f"{prefix}{text}{C.RESET}"


def dim(text):
    return styled(text, C.DIM)


def bold(text):
    return styled(text, C.BOLD)


def term_width():
    return shutil.get_terminal_size((80, 24)).columns


def hrule():
    return dim("─" * min(term_width(), 72))


def wrap_text(text, indent=0):
    """Wrap text to terminal width with indent."""
    width = min(term_width() - indent, 80)
    lines = text.split("\n")
    result = []
    for line in lines:
        if len(line) <= width:
            result.append(line)
        else:
            wrapped = textwrap.wrap(line, width=width)
            result.extend(wrapped if wrapped else [""])
    return "\n".join((" " * indent + l) for l in result)


# ─── Simple Markdown Rendering ──────────────────────────────────────────────

def render_markdown(text):
    """Render basic markdown with ANSI codes for terminal display."""
    if not TERM_CAPS["color"]:
        return text

    lines = text.split("\n")
    result = []
    in_code_block = False
    code_lang = ""

    for line in lines:
        # Code blocks
        if line.startswith("```"):
            in_code_block = not in_code_block
            if in_code_block:
                code_lang = line[3:].strip()
                result.append(dim("┌─" + (f" {code_lang} " if code_lang else "") + "─" * 40))
            else:
                result.append(dim("└" + "─" * 44))
                code_lang = ""
            continue

        if in_code_block:
            result.append(f"  {styled(line, C.CYAN)}")
            continue

        # Headers
        if line.startswith("### "):
            result.append(styled(line[4:], C.BOLD, C.MAGENTA))
            continue
        if line.startswith("## "):
            result.append(styled(line[3:], C.BOLD, C.YELLOW))
            continue
        if line.startswith("# "):
            result.append(styled(line[2:], C.BOLD, C.GREEN))
            continue

        # Inline code
        line = re.sub(r'`([^`]+)`', lambda m: styled(m.group(1), C.CYAN), line)
        # Bold
        line = re.sub(r'\*\*([^*]+)\*\*', lambda m: styled(m.group(1), C.BOLD), line)
        # Italic
        line = re.sub(r'\*([^*]+)\*', lambda m: styled(m.group(1), C.ITALIC), line)
        # Bullet points
        if line.startswith("- ") or line.startswith("* "):
            line = f"  {styled('•', C.CYAN)} {line[2:]}"

        result.append(line)

    return "\n".join(result)


# ─── Spinner ────────────────────────────────────────────────────────────────

class Spinner:
    """Animated spinner for waiting states."""
    def __init__(self, message="Thinking"):
        self.message = message
        self.running = False
        self.thread = None
        self.frame = 0

    def start(self):
        self.running = True
        self.thread = threading.Thread(target=self._animate, daemon=True)
        self.thread.start()

    def _animate(self):
        while self.running:
            frame = Icons.SPINNER_FRAMES[self.frame % len(Icons.SPINNER_FRAMES)]
            sys.stdout.write(f"\r{styled(frame, C.CYAN)} {dim(self.message)}  ")
            sys.stdout.flush()
            self.frame += 1
            time.sleep(0.08)

    def stop(self):
        self.running = False
        if self.thread:
            self.thread.join()
        sys.stdout.write("\r" + " " * (len(self.message) + 10) + "\r")
        sys.stdout.flush()


# ─── Image Handling ─────────────────────────────────────────────────────────

def display_image_iterm(data, filename="image"):
    """Display image using iTerm2 inline image protocol."""
    b64 = base64.b64encode(data).decode("ascii")
    sys.stdout.write(f"\033]1337;File=name={base64.b64encode(filename.encode()).decode()};inline=1:{b64}\007\n")
    sys.stdout.flush()


def display_image_kitty(data, filename="image"):
    """Display image using Kitty graphics protocol."""
    b64 = base64.b64encode(data).decode("ascii")
    # Send in chunks of 4096
    chunks = [b64[i:i+4096] for i in range(0, len(b64), 4096)]
    for i, chunk in enumerate(chunks):
        m = 1 if i < len(chunks) - 1 else 0
        if i == 0:
            sys.stdout.write(f"\033_Ga=T,f=100,m={m};{chunk}\033\\")
        else:
            sys.stdout.write(f"\033_Gm={m};{chunk}\033\\")
    sys.stdout.write("\n")
    sys.stdout.flush()


def display_image(data, filename="image"):
    """Display image using best available terminal protocol."""
    if TERM_CAPS["kitty_images"] or TERM_CAPS["ghostty_images"]:
        display_image_kitty(data, filename)
    elif TERM_CAPS["iterm_images"]:
        display_image_iterm(data, filename)
    else:
        print(dim(f"  [{Icons.IMAGE}{filename} - image display not supported in this terminal]"))


def encode_image_for_api(filepath):
    """Read and encode an image file for the chat completions API."""
    ext = os.path.splitext(filepath)[1].lower()
    mime_types = {
        ".png": "image/png", ".jpg": "image/jpeg", ".jpeg": "image/jpeg",
        ".gif": "image/gif", ".webp": "image/webp",
    }
    mime = mime_types.get(ext, "image/png")
    with open(filepath, "rb") as f:
        data = f.read()
    b64 = base64.b64encode(data).decode("ascii")
    return {"type": "image_url", "image_url": {"url": f"data:{mime};base64,{b64}"}}


