def print_banner():
    """Show welcome banner with key info."""
    w = min(term_width(), 60)
    print()
    print(styled("  ╭" + "─" * (w - 4) + "╮", C.DIM))
    title = "llm-chat"
    pad = w - 4 - len(title) - 3
    print(styled("  │", C.DIM) + f" {styled(Icons.SPARKLE, C.BRIGHT_MAGENTA)}{styled(title, C.BOLD)} " + " " * pad + styled("│", C.DIM))
    print(styled("  ╰" + "─" * (w - 4) + "╯", C.DIM))
    print()


def setup_connection(args):
    """Establish API connection, prompting as needed. Returns LLMClient."""
    config = load_config()
    provider_name = args.get("provider")
    provider = PROVIDERS.get(provider_name) if provider_name else None

    # Resolve base URL: args > provider > env > config > show help
    if args.get("base_url"):
        base_url = args["base_url"]
    elif provider:
        base_url = provider["base_url"]
    else:
        base_url = (
            os.environ.get("LLM_BASE_URL")
            or os.environ.get("OPENAI_BASE_URL")
            or config.get("base_url")
        )
        if not base_url:
            print_help()
            sys.exit(0)

    # Resolve API key: args > provider-specific env/files > generic env > config > prompt
    api_key = args.get("api_key")
    if not api_key and provider_name:
        api_key = resolve_provider_key(provider_name)
    if not api_key:
        api_key = (
            os.environ.get("LLM_API_KEY")
            or os.environ.get("OPENAI_API_KEY")
            or config.get("api_key")
        )

    client = LLMClient(base_url, api_key)
    print(f"  {dim('Connecting to')} {styled(base_url, C.UNDERLINE)}")

    # Test connection
    ok, err = client.test_connection()
    if not ok:
        if err == "unauthorized":
            print(f"  {Icons.WARN}API key required")
            try:
                api_key = input(f"  {dim('API Key: ')}").strip()
            except (EOFError, KeyboardInterrupt):
                print("\n")
                sys.exit(1)
            client.api_key = api_key
            ok, err = client.test_connection()
            if not ok:
                print(f"  {styled('Error:', C.RED)} {err}")
                sys.exit(1)
            # Save for next time
            config["api_key"] = api_key
            config["base_url"] = base_url
            save_config(config)
        else:
            print(f"  {styled('Error:', C.RED)} {err}")
            sys.exit(1)
    else:
        # Save working config
        config["base_url"] = base_url
        if api_key:
            config["api_key"] = api_key
        save_config(config)

    print(f"  {Icons.CHECK}{styled('Connected', C.GREEN)}")

    # Select model: args > env > config > interactive
    model = (
        args.get("model")
        or os.environ.get("LLM_MODEL")
        or config.get("model")
    )

    if not model:
        models = client.list_models()
        if not models:
            print(f"  {Icons.WARN}No models found at /models endpoint")
            try:
                model = input(f"  {dim('Model name: ')}").strip()
            except (EOFError, KeyboardInterrupt):
                print("\n")
                sys.exit(1)
        elif len(models) == 1:
            model = models[0]
            print(f"  {dim('Using only available model:')} {styled(model, C.BOLD)}")
        else:
            print(f"\n  {bold('Select a model:')}")
            for i, m in enumerate(models[:20], 1):
                print(f"    {styled(str(i), C.DIM)}) {m}")
            if len(models) > 20:
                print(dim(f"    ... and {len(models) - 20} more (/models to see all)"))
            print()
            try:
                choice = input(dim("  Choice (number or name): ")).strip()
            except (EOFError, KeyboardInterrupt):
                print("\n")
                sys.exit(1)
            if choice.isdigit() and 1 <= int(choice) <= len(models):
                model = models[int(choice) - 1]
            elif choice in models:
                model = choice
            else:
                matches = [m for m in models if choice.lower() in m.lower()]
                model = matches[0] if matches else choice

    client.model = model
    config["model"] = model
    save_config(config)
    print(f"  {dim('Model:')} {styled(model, C.BOLD)}")
    print()
    return client


