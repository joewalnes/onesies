def parse_args():
    """Parse command-line arguments."""
    args = {}
    argv = sys.argv[1:]
    i = 0
    while i < len(argv):
        a = argv[i]
        if a in ("-u", "--url", "--base-url"):
            i += 1
            args["base_url"] = argv[i] if i < len(argv) else None
        elif a in ("-k", "--key", "--api-key"):
            i += 1
            args["api_key"] = argv[i] if i < len(argv) else None
        elif a in ("-m", "--model"):
            i += 1
            args["model"] = argv[i] if i < len(argv) else None
        elif a in ("-s", "--system"):
            i += 1
            args["system"] = argv[i] if i < len(argv) else None
        elif a in _PROVIDER_ALIAS_MAP:
            args["provider"] = _PROVIDER_ALIAS_MAP[a]
        elif a in ("-h", "--help"):
            print_help()
            sys.exit(0)
        elif a.startswith("http"):
            args["base_url"] = a
        else:
            if not a.startswith("-"):
                args["model"] = a
        i += 1
    return args


# ─── Main Loop ──────────────────────────────────────────────────────────────

def get_input(session):
    """Get user input with support for multi-line (backslash continuation) and Ctrl+X Ctrl+E."""
    prompt = f"{styled(Icons.USER, C.BRIGHT_CYAN)}"
    lines = []

    while True:
        try:
            if lines:
                line = input(styled("  ... ", C.DIM))
            else:
                line = input(prompt)
        except EOFError:
            if lines:
                return "\n".join(lines)
            raise
        except KeyboardInterrupt:
            if lines:
                print()
                lines.clear()
                continue
            raise

        # Check for editor trigger: if line is just `:e` or user pressed Ctrl+X Ctrl+E
        if line.strip() == ":e" or line.strip() == ":edit":
            initial = "\n".join(lines) if lines else ""
            result = open_in_editor(initial)
            if result is not None:
                return result.rstrip("\n")
            lines.clear()
            continue

        # Multi-line continuation
        if line.endswith("\\"):
            lines.append(line[:-1])
            continue

        lines.append(line)
        return "\n".join(lines)


def handle_file_path_input(session, text):
    """Check if input looks like a file path and offer to attach it."""
    # Detect pasted file paths (common pattern: starts with / or ~, has image extension)
    stripped = text.strip().strip("'\"")
    if (stripped.startswith("/") or stripped.startswith("~")) and os.path.exists(os.path.expanduser(stripped)):
        ext = os.path.splitext(stripped)[1].lower()
        image_exts = {".png", ".jpg", ".jpeg", ".gif", ".webp"}
        if ext in image_exts:
            session.attached_files.append(os.path.expanduser(stripped))
            print(f"  {Icons.IMAGE}Image attached: {os.path.basename(stripped)}")
            print(dim(f"  Type your message (image will be included) or paste another file"))
            return True
    return False


def main():
    signal.signal(signal.SIGINT, lambda s, f: (print(f"\n  {dim('Goodbye!')}"), save_readline_history(), sys.exit(0)))

    args = parse_args()
    print_banner()

    # Setup
    setup_readline()
    import atexit
    atexit.register(save_readline_history)

    client = setup_connection(args)
    session = ChatSession(client)

    if args.get("system"):
        session.set_system(args["system"])
        print(f"  {dim('System prompt set from --system flag')}")

    # Welcome hints
    print(hrule())
    features = [f"{styled('/help', C.CYAN)} commands"]
    features.append(f"{styled(':edit', C.CYAN)} opens $EDITOR")
    if TERM_CAPS["images"]:
        features.append(f"{styled('/attach', C.CYAN)} images")
    bslash = styled("\\\\", C.CYAN)
    features.append(f"{bslash} for multi-line")
    print(f"  {dim(' │ '.join(features))}")
    print(hrule())
    print()

    # Main REPL
    while True:
        try:
            text = get_input(session)
        except EOFError:
            print(f"\n  {dim('Goodbye!')}")
            break
        except KeyboardInterrupt:
            print(f"\n  {dim('Goodbye!')}")
            break

        if not text.strip():
            continue

        # Handle slash commands
        if text.startswith("/"):
            parts = text[1:].split(None, 1)
            cmd_name = parts[0].lower() if parts else ""
            cmd_args = parts[1] if len(parts) > 1 else ""
            if cmd_name in COMMANDS:
                COMMANDS[cmd_name](session, cmd_args)
            else:
                print(f"  {Icons.WARN}Unknown command: /{cmd_name}  {dim('(try /help)')}")
            continue

        # Check for file path paste
        if handle_file_path_input(session, text):
            continue

        # Handle pending text file attachments
        if hasattr(session, '_pending_text_files') and session._pending_text_files:
            file_context = ""
            for fname, content in session._pending_text_files:
                file_context += f"\n\n--- File: {fname} ---\n{content}\n---\n"
            text = text + file_context
            session._pending_text_files.clear()
            # Remove None markers from attached_files
            session.attached_files = [f for f in session.attached_files if f is not None]

        # Send message
        session.add_user_message(text)
        session.stream_response()
        print()


if __name__ == "__main__":
    main()
