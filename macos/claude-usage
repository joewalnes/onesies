#!/usr/bin/swift

// macOS menu bar app showing Anthropic API usage and rate limits
//
// You can execute this file directly (no need to compile, or use Xcode).
//
//   $ ./claude-usage
//
// ============================================================
// COST OF RUNNING THIS APP
// ============================================================
//
// Anthropic has NO free "check my limits" endpoint. To read your rate
// limit status, this app must make a real API call and inspect the
// response headers. It uses the cheapest possible call: one message
// to claude-haiku-4-5 requesting max_tokens=1.
//
// The app auto-discovers the cheapest model (Haiku) via GET /v1/models
// on startup, so you never need to update a hardcoded model name.
//
// Cost per probe (Haiku pricing as of March 2026):
//   ~10 input tokens × $1.00/MTok  = $0.00001
//   ~1 output token  × $5.00/MTok  = $0.000005
//   Total per probe                ≈ $0.000015
//
// At the default 5-minute refresh interval:
//   Per day:   288 probes × $0.000015  ≈  $0.004
//   Per month: 8,640 probes × $0.000015 ≈  $0.13
//
// So roughly 10–15 cents per month. Adjust refreshInterval below
// to trade frequency for cost.
//
// With an Admin API key, the usage and cost data comes from the
// Admin API which is free and does NOT count against rate limits.
// Only the rate-limit probe costs money.
//
// ============================================================
//
// API key setup:
//   On first run, click the ✳ menu bar icon and choose "Set API Key..."
//   to paste your key. It will be stored in the macOS Keychain.
//
//   Alternatively, set an environment variable:
//     export ANTHROPIC_API_KEY=sk-ant-...
//     export ANTHROPIC_ADMIN_API_KEY=sk-ant-admin...  (for usage+cost)
//
// Features:
//   - Menu bar ✳ with percentage showing remaining rate limit capacity
//   - Color-coded warnings (default → orange → red as limits approach)
//   - Progress bars for requests, input tokens, output tokens
//   - Today's usage breakdown with Admin API key (tokens + cost)
//   - API key stored securely in macOS Keychain
//   - Auto-refresh on configurable interval
//   - Zero dependencies beyond macOS system frameworks
//
// - Joe Walnes

import Cocoa
import Foundation
import Security

// AIDEV-NOTE: User Configuration - Easy to modify settings
// ========================================================

struct UsageConfig {
    // Refresh interval: seconds between rate limit probes.
    // See cost table in header comment. 300s ≈ $0.13/month with Haiku.
    static var refreshInterval: TimeInterval = 300

    // AIDEV-NOTE: probeModel is auto-discovered at startup by calling
    // GET /v1/models and picking the cheapest (Haiku) model. This avoids
    // hardcoding a model name that will go stale when new versions ship.
    // The fallback is only used if the models endpoint fails.
    static var probeModel = "claude-haiku-4-5"  // fallback if auto-discovery fails
    static let probeModelFallback = "claude-haiku-4-5"

    // Warning thresholds (fraction of capacity remaining)
    static var warningThreshold = 0.25       // Orange below 25%
    static var criticalThreshold = 0.10      // Red below 10%

    // Display
    static let menuBarFont = NSFont.monospacedDigitSystemFont(ofSize: 12, weight: .medium)
    static let menuItemFont = NSFont.monospacedSystemFont(ofSize: 11, weight: .regular)
    static let sectionFont = NSFont.systemFont(ofSize: 12, weight: .semibold)

    // Progress bar appearance
    static let barWidth = 10                 // Characters wide
    static let barFilled: Character = "█"
    static let barEmpty: Character = "░"

    // Keychain
    static let keychainService = "claude-usage"
    static let keychainAccount = "anthropic-api-key"

    // Anthropic Console URL for getting API keys
    static let apiKeysURL = "https://console.anthropic.com/settings/keys"
}

// ============================================================
